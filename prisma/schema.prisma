  confidence     Float?
  overrodeManual String? // اگر غیرنال باشد یعنی انتخاب دستی کاربر بی‌صدا override شد
  createdAt      DateTime  @default(now())

  @@index([userId, createdAt])
  @@map("model_routing_logs")
}

