  maxImageSizeMb          Int      @default(8) // سقف سایز هر عکس بعد از decode
  allowedImageFormats     Json     @default("[\"png\",\"jpeg\",\"webp\",\"gif\"]") // string[] — فقط از این چهارتا که magic-byte برایشان چک می‌شود
  implicitImageGenEnabled Boolean  @default(true) // تشخیص خودکار نیت تولید عکس وسط چت معمولی (بدون toggle صریح) — heuristic، نه قطعی
