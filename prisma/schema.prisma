generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String?
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // docs/PRD-growth-traction-features.md بخش ۳.۲ — denormalized، هر پیام (نه فقط امروز) اینکریمنت می‌شود
  lifetimeMessageCount Int       @default(0)
  // لحظه‌ی دقیقی که کاربر از trial خارج شد (lifetimeMessageCount اولین‌بار به trialMessageThreshold
  // رسید) — برای پنجره‌ی مهلت ۲۴ساعته‌ی claim کد تخفیف هدیه بعد از پایان trial (بخش ۳.۵)
  trialEndedAt         DateTime?

  // docs/PRD-growth-traction-features.md بخش ۶.۲ — معرفی دوستان
  referralCode     String  @unique
  referredByUserId String?
  referredByUser   User?   @relation("Referrals", fields: [referredByUserId], references: [id])
  referredUsers    User[]  @relation("Referrals")

  conversations             Conversation[]
  messages                  Message[]
  subscription              Subscription?
  payments                  Payment[]
  invoices                  Invoice[]
  refreshTokens             RefreshToken[]
  dailyUsages               DailyUsage[]
  feedbacks                 Feedback[]
  quotaOverride             UserQuotaOverride?
  wallet                    Wallet?
  tickets                   SupportTicket[]
  limitHitEvents            LimitHitEvent[]
  liaraApiKey               LiaraApiKey?
  liaraUsageSnapshots       LiaraUsageSnapshot[]
  liaraKeyProvisioningIssue LiaraKeyProvisioningIssue?
  adminDeviceTokens         AdminDeviceToken[]         @relation("AdminDeviceTokens")
  deviceTokens              DeviceToken[]              @relation("UserDeviceTokens")
  pushCampaigns             PushCampaign[]             @relation("PushCampaignCreatedBy")
  waitlistEntry             WaitlistEntry?
  issuedDiscountCodes       DiscountCode[]             @relation("IssuedDiscountCodes")
  discountRedemptions       DiscountCodeRedemption[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model Plan {
  id                    String  @id @default(uuid())
  name                  String  @unique
  priceMonthly          Int // تومان
  dailyFreeTokens       Int
  monthlyTotalTokens    Int
  allowedModels         Json
  features              Json    @default("{}")
  isActive              Boolean @default(true)
  sortOrder             Int     @default(0)
  isPopular             Boolean @default(false) // نشان «محبوب‌ترین» روی کارت پلن
  featuredModels        Json    @default("[]") // string[] — زیرمجموعه‌ی ترتیب‌دار allowedModels — مدل‌های ویژه‌ی این پلن (منبع دراپ‌داون چت + چیپ‌های کارت)
  featuredModelsCount   Int     @default(5) // چند مورد از featuredModels روی کارت (قبل از «N مدل دیگر») نشان داده شود
  maxInputTokens        Int     @default(300)
  outputThrottleSteps   Json    @default("[]")
  dailyMessageLimit     Int?
  throttledMessageCount Int?
  throttledInputTokens  Int?
  throttledOutputTokens Int?
  rollingWindowLimit    Int? // سقف پیام در پنجره‌ی لغزان — null = غیرفعال برای این پلن (docs/PRD-global-budget-gateway.md بخش ۸)
  rollingWindowHours    Int     @default(3)

  simpleModel String? @default("openai/gpt-5-nano") // مدل ثابت برای پیام‌های SIMPLE این پلن — کف‌ترین/دیفالت‌ترین مدل

  // میزان reasoning effort برای پاسخ اصلی چت این پلن (مدل‌های reasoning مثل خانواده‌ی gpt-5) —
  // 'minimal' | 'low' | 'medium' | 'high'؛ null = پیش‌فرض provider (معمولاً medium). می‌تواند
  // به‌ازای هر استپ بودجه‌ای (PlanRoutingStep.reasoningEffort) override شود. اگر کاربر از
  // دراپ‌دون «سریع/هوشمند» کنار ارسال پیام انتخاب کند، به‌جای این مقدار fastReasoningEffort/
  // smartReasoningEffort استفاده می‌شود؛ این‌جا فقط پیش‌فرض وقتی هیچ‌کدام انتخاب نشده باشد.
  reasoningEffort String?
  // معادل حالت «سریع» دراپ‌دون کنار ارسال پیام — انتخاب مدل را عوض نمی‌کند، فقط این مقدار به‌جای
  // reasoningEffort بالا استفاده می‌شود. null = 'none' (بدون فکر)
  fastReasoningEffort String?
  // معادل حالت «هوشمند» دراپ‌دون کنار ارسال پیام. null = 'low' (فکر کم)
  smartReasoningEffort String?

  // context اختصاصی این پلن — بعد از context عمومی (ChatConfig.globalContextMd) به system prompt چت اصلی اضافه می‌شود
  // (docs/PRD-chat-context-and-summarization.md بخش ۴)
  contextMd String? @db.Text

  // دوره‌ی آزمایشی کاربر تازه (docs/PRD-growth-traction-features.md بخش ۳) — مادامی که
  // User.lifetimeMessageCount از trialMessageThreshold کمتر است، به‌جای محدودیت‌های همیشگی
  // بالا از این مقادیر استفاده می‌شود؛ null = از مقدار همیشگی استفاده کن
  trialMessageThreshold      Int?
  trialDailyMessageLimit     Int?
  trialThrottledMessageCount Int?
  trialRollingWindowLimit    Int?
  trialRollingWindowHours    Int?

  // docs/PRD-pay-as-you-go-wallet.md — پلن مصرفی: بدون بودجه‌ی روزانه/ماهانه مشتق از priceMonthly،
  // بدون fallback پله‌ای PlanRoutingStep؛ مصرف واقعی × payAsYouGoMarkup از Wallet کاربر کم می‌شود
  isPayAsYouGo                 Boolean @default(false)
  payAsYouGoMarkup             Float?  @default(1.3)
  payAsYouGoMinActivationToman Int?    @default(1000000)
  payAsYouGoMinTopupToman      Int?    @default(500000)
  payAsYouGoTopupPresets       Json?   @default("[1000000,2000000,5000000]")

  // تنظیمات تولید/ویرایش عکس مخصوص این پلن — اگر defaultImageGenModel ست شود، به‌جای
  // طبقه‌بندی خودکار prompt (SIMPLE/MEDIUM/COMPLEX)، اول همین مدل مشخص (با کیفیت/ابعاد خودش)
  // امتحان می‌شود؛ اگر fail کند، به بقیه‌ی مدل‌های supportsImageGen این پلن fallback می‌شود.
  // سقف‌های تعداد درخواست هم مستقل از سهمیه‌ی توکنی/پیامی معمولی این پلن هستند — چون هر عکس
  // چند برابر گران‌تر از یک پیام متنی است.
  defaultImageGenModel String?
  maxImageGenPerDay    Int? // null = بدون سقف روزانه
  maxImageGenPerWindow Int? // null = بدون سقف پنجره‌ی لغزان
  imageGenWindowHours  Int?    @default(24)

  subscriptions Subscription[]
  payments      Payment[]
  routingSteps  PlanRoutingStep[]

  @@map("plans")
}

// استپ‌های مسیریابی مدل بر اساس درصد مصرف بودجه‌ی روزانه — هر پلن چند استپ دارد،
// هر استپ یک استخر مدل ترتیب‌دار (drag&drop در ادمین) برای یک بازه‌ی مصرف مشخص می‌کند
model PlanRoutingStep {
  id              String   @id @default(uuid())
  planId          String
  order           Int // ترتیب استپ (۱، ۲، ۳، ...)
  thresholdPct    Int // سقف تجمعی درصد مصرف روزانه (مثلاً ۶۰، ۹۰، ۱۰۰)
  models          Json // string[] ترتیب‌دار — استخر مدل‌های این استپ (زیرمجموعه‌ی allowedModels پلن)
  // override میزان reasoning effort فقط برای همین استپ — null یعنی از Plan.reasoningEffort ارث می‌برد
  reasoningEffort String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, order])
  @@index([planId])
  @@map("plan_routing_steps")
}

model Subscription {
  id                String             @id @default(uuid())
  userId            String             @unique
  planId            String
  status            SubscriptionStatus @default(ACTIVE)
  periodStart       DateTime
  periodEnd         DateTime
  cancelAtPeriodEnd Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
}

model Conversation {
  id                       String    @id @default(uuid())
  userId                   String
  title                    String?
  model                    String
  systemPrompt             String?
  totalTokens              Int       @default(0)
  isArchived               Boolean   @default(false)
  lastMessageAt            DateTime  @default(now())
  createdAt                DateTime  @default(now())
  contextSummary           String?
  summarizedAt             DateTime?
  // پیام‌های تا این timestamp قبلاً توی contextSummary خلاصه شده‌اند — برای واکشی فقط
  // پیام‌های «بعد از آخرین خلاصه‌سازی» (docs/PRD-chat-context-and-summarization.md بخش ۳.۱)
  summarizedUntilCreatedAt DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, lastMessageAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id                  String      @id @default(uuid())
  conversationId      String
  userId              String? // denormalized از conversation.userId — برای groupBy تجمیعی آنالیز مصرف (بخش ۱۷) بدون join
  role                MessageRole
  content             String
  images              Json?
  tokensInput         Int         @default(0)
  tokensOutput        Int         @default(0)
  costToman           Int         @default(0) // هزینه‌ی دقیق همین پیام (تومان)، در لحظه‌ی ایجاد محاسبه‌شده — نه بازمحاسبه‌ی بعدی با نرخ/قیمت فعلی
  costUsdMicros       Int         @default(0)
  costInputUsdMicros  Int         @default(0) // سهم توکن ورودی از costUsdMicros — برای میانگین وزنی قیمت ورودی/خروجی در آنالیز (بدون بازمحاسبه با قیمت فعلی مدل)
  costOutputUsdMicros Int         @default(0)
  model               String?
  topicId             String?
  createdAt           DateTime    @default(now())

  conversation Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedback     MessageFeedback?
  topic        Topic?           @relation(fields: [topicId], references: [id])

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@index([topicId, createdAt])
  @@map("messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Payment {
  id             String          @id @default(uuid())
  userId         String
  kind           PaymentKind     @default(SUBSCRIPTION) // docs/PRD-pay-as-you-go-wallet.md — WALLET_TOPUP پلن ندارد
  planId         String? // فقط SUBSCRIPTION — WALLET_TOPUP این را null می‌گذارد
  amount         Int // تومان — بعد از اعمال تخفیف (اگر کد تخفیف استفاده شده باشد)
  status         PaymentStatus   @default(PENDING)
  provider       PaymentProvider @default(ZARINPAL)
  providerRef    String?         @unique
  refId          String?
  metadata       Json?
  discountCodeId String? // docs/PRD-growth-traction-features.md بخش ۵.۲
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user         User                    @relation(fields: [userId], references: [id])
  plan         Plan?                   @relation(fields: [planId], references: [id])
  discountCode DiscountCode?           @relation(fields: [discountCodeId], references: [id])
  invoice      Invoice?
  redemption   DiscountCodeRedemption?

  @@index([userId])
  @@map("payments")
}

enum PaymentKind {
  SUBSCRIPTION
  WALLET_TOPUP
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// فقط برای پرداخت‌های COMPLETED صادر می‌شود — رسید داخلی، نه فاکتور رسمی سامانه‌ی مودیان
// (آن بخش موضوع حقوقی/مالیاتی جداست و در این نسخه پیاده‌سازی نشده)
model Invoice {
  id         String          @id @default(uuid())
  number     Int             @unique @default(autoincrement())
  paymentId  String          @unique
  userId     String
  planName   String? // WALLET_TOPUP پلنی ندارد — «شارژ کیف‌پول» به‌جایش نوشته می‌شود
  amount     Int // تومان — مبلغ نهایی پرداخت‌شده
  taxAmount  Int             @default(0) // تومان — رزرو برای مالیات بر ارزش افزوده در آینده، فعلاً محاسبه نمی‌شود
  provider   PaymentProvider
  refId      String?
  buyerName  String?
  buyerPhone String
  issuedAt   DateTime        @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("invoices")
}

enum PaymentProvider {
  ZARINPAL
  VANDAR
  ZIBAL
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model DailyUsage {
  id             String   @id @default(uuid())
  userId         String
  date           DateTime @db.Date
  freeTokensUsed Int      @default(0)
  paidTokensUsed Int      @default(0)
  requestsCount  Int      @default(0)
  costToman      Int      @default(0)
  costUsdMicros  Int      @default(0) // دلار × ۱٬۰۰۰٬۰۰۰ — نگه‌داشتن هزینه‌ی خام دلاری، مستقل از نوسان نرخ ارز

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@map("daily_usage")
}

// docs/PRD-liara-usage-reconciliation.md — یک کلید API اختصاصی روی لیارا به‌ازای هر
// کاربر (نه کلید مشترک پلتفرم)، تا مصرف واقعی هر کاربر از لاگ‌های خودِ لیارا قابل تفکیک باشد.
// encryptedKey اولین secret خامی است که در این پروژه در دیتابیس نگه داشته می‌شود — رمزنگاری‌شده
// با secret-cipher.ts (AES-256-GCM)، نه plain text.
model LiaraApiKey {
  id           String   @id @default(uuid())
  userId       String   @unique
  keyName      String   @unique // نام کوتاه روی لیارا — الگوی u+۱۴کاراکتر hex (محدودیت لیارا: ۳-۱۵ کاراکتر)
  encryptedKey String // مقدار خام کلید، رمزنگاری‌شده — فقط یک‌بار در پاسخ ساخت از لیارا برمی‌گردد
  liaraKeyId   String? // فیلد _id برگشتی از لیارا، برای مدیریت/حذف آینده
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("liara_api_keys")
}

// roll-up روزانه‌ی مصرف واقعیِ گزارش‌شده توسط لیارا (از GET /ai-logs/logs، فیلترشده با کلید
// اختصاصی همین کاربر) — برای مقایسه‌ی «عدد داخلی ما» در برابر «عدد واقعی لیارا» در پنل آنالیز.
// فقط از لحظه‌ی فعال‌شدن LiaraApiKey برای هر کاربر به بعد داده دارد؛ بازه‌های قبل‌تر عمداً رکورد ندارند.
model LiaraUsageSnapshot {
  id                 String   @id @default(uuid())
  userId             String
  date               DateTime @db.Date
  realTokensTotal    Int      @default(0)
  realCostToman      Int      @default(0)
  realTextCostToman  Int      @default(0)
  realImageCostToman Int      @default(0)
  requestCount       Int      @default(0)
  syncedAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@map("liara_usage_snapshots")
}

// کاربرانی که تلاش برای ساخت کلید اختصاصی‌شان fail شده (JWT مدیریتی نامعتبر، لیارا در دسترس
// نیست، ...) — تا وقتی موفق نشده این ردیف می‌ماند، هم برای نمایش در پنل ادمین (چند کاربر الان
// روی کلید مشترک fallback هستند و چرا) و هم به‌عنوان صف retry جاب دوره‌ای. با موفقیت هر تلاش
// (لازی در chat.service یا از جاب retry) این ردیف حذف می‌شود.
model LiaraKeyProvisioningIssue {
  id            String   @id @default(uuid())
  userId        String   @unique
  lastError     String
  attemptCount  Int      @default(1)
  firstFailedAt DateTime @default(now())
  lastAttemptAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("liara_key_provisioning_issues")
}

enum FeedbackCategory {
  FEATURE_REQUEST
  BUG
  UX
  PRICING
  GENERAL
}

model Feedback {
  id        String           @id @default(uuid())
  userId    String?
  category  FeedbackCategory @default(GENERAL)
  content   String
  isChecked Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([isChecked, createdAt])
  @@map("feedbacks")
}

model FeedbackSummary {
  id          String   @id @default(uuid())
  summary     String
  topItems    Json
  totalCount  Int      @default(0)
  checkedUpTo DateTime @default(now())
  createdAt   DateTime @default(now())

  @@map("feedback_summaries")
}

// ─── Quota Overrides ───────────────────────────────────────────────────────────

model UserQuotaOverride {
  id                  String   @id @default(uuid())
  userId              String   @unique
  maxInputTokens      Int?
  outputThrottleSteps Json?
  dailyBudgetToman    Int? // تومان
  note                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_quota_overrides")
}

// ─── Wallet ────────────────────────────────────────────────────────────────────

model Wallet {
  id           String   @id @default(uuid())
  userId       String   @unique
  balanceToman Int      @default(0) // تومان
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String       @id @default(uuid())
  walletId    String
  type        WalletTxType
  amountToman Int // تومان
  description String?
  metadata    Json?
  createdAt   DateTime     @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

enum WalletTxType {
  CREDIT
  DEBIT
}

// ─── Support Tickets ───────────────────────────────────────────────────────────

model SupportTicket {
  id        String         @id @default(uuid())
  userId    String
  subject   String
  body      String
  status    TicketStatus   @default(OPEN)
  priority  TicketPriority @default(NORMAL)
  adminNote String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies TicketReply[]

  @@index([status, createdAt])
  @@map("support_tickets")
}

model TicketReply {
  id        String   @id @default(uuid())
  ticketId  String
  fromAdmin Boolean  @default(false)
  body      String
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_replies")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ModelTier {
  SIMPLE
  MEDIUM
  COMPLEX
}

// چت‌محور (تولید متن) در برابر embedding — docs/PRD-sales-kb-rag-and-plan-context.md.
// جدا نگه‌داشتن این انواع در همان جدول AiModel لازم است تا مدل‌های embedding در
// دراپ‌داون‌های چت (پلن‌ها، مسیریاب مدل، کاتالوگ عمومی) سهواً انتخاب‌پذیر نشوند.
// IMAGE_GEN — مدل‌هایی که فقط تولید عکس می‌کنند و اصلاً قابلیت تولید متن/چت ندارند؛
// عمداً از فیلتر `modelType: 'CHAT'` مسیریاب مدل (model-router.service.ts) بیرون می‌مانند
// تا هرگز برای پاسخ‌دهی متنی معمولی انتخاب نشوند — حتی اگر توی allowedModels یک پلن باشند.
enum AiModelType {
  CHAT
  EMBEDDING
  IMAGE_GEN
}

model AiModel {
  id                           String      @id @default(uuid())
  name                         String      @unique
  displayName                  String
  provider                     String
  modelType                    AiModelType @default(CHAT)
  inputPricePerM               Float       @default(0)
  outputPricePerM              Float       @default(0)
  supportsVision               Boolean     @default(false)
  supportsImageGen             Boolean     @default(false) // docs/PRD-chat-images.md — تولید عکس
  // قیمت‌گذاری تولید عکس بر اساس توکن واقعی مصرف‌شده است (نه یک عدد ثابت هر عکس) — درست مثل
  // مدل‌های چت. سه نرخ لازم است چون هر کدام یک نوع توکن جدا است:
  //   ۱) متن ورودی (prompt) → همان inputPricePerM بالا دوباره استفاده می‌شود
  //   ۲) عکس ورودی (فقط حالت ویرایش/edit، وقتی کاربر عکس می‌دهد) → imageGenInputImagePricePerM
  //   ۳) عکس خروجی (تصویر تولیدشده) → imageGenOutputImagePricePerM
  // هزینه‌ی هر درخواست از usage واقعی پاسخ provider محاسبه می‌شود (chat.service.ts —
  // generateImageRaw/editImageRaw)، نه از این نرخ‌ها به‌تنهایی؛ این‌ها فقط قیمت هر ۱M توکن‌اند.
  imageGenInputImagePricePerM  Float?
  imageGenOutputImagePricePerM Float?
  imageGenQuality              String? // دقیقاً همان رشته‌ای که به provider پاس داده می‌شود — مثل "low"/"medium"/"high" (خانواده‌ی gpt-image) یا "standard"/"hd" (dall-e-3)
  imageGenSize                 String? // مثل "1024x1024" — مستقیم به provider پاس داده می‌شود
  isActive                     Boolean     @default(true)
  sortOrder                    Int         @default(0)
  tier                         ModelTier   @default(MEDIUM)
  createdAt                    DateTime    @default(now())

  // شمارش دقیق توکن — برای مدل‌های OpenAI-family یک tokenizer واقعی داریم؛
  // برای بقیه‌ی پروایدرها (Claude، Grok، ...) که tokenizer آفلاین ندارند،
  // یک نسبت کاراکتر/توکن قابل‌کالیبره در ادمین استفاده می‌شود.
  tokenizerFamily  String @default("approximate") // "o200k_base" | "cl100k_base" | "approximate"
  avgCharsPerToken Float  @default(4) // فقط وقتی tokenizerFamily="approximate" استفاده می‌شود

  @@map("ai_models")
}

// ─── Model Router ──────────────────────────────────────────────────────────────

// تنظیمات سراسری مسیریابی مدل — تک‌رکوردی (singleton، با id ثابت "default")
model ModelRoutingConfig {
