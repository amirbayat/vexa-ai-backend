generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String?
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // docs/PRD-growth-traction-features.md بخش ۳.۲ — denormalized، هر پیام (نه فقط امروز) اینکریمنت می‌شود
  lifetimeMessageCount Int @default(0)

  // docs/PRD-growth-traction-features.md بخش ۶.۲ — معرفی دوستان
  referralCode     String  @unique
  referredByUserId String?
  referredByUser   User?   @relation("Referrals", fields: [referredByUserId], references: [id])
  referredUsers    User[]  @relation("Referrals")

  conversations      Conversation[]
  messages           Message[]
  subscription       Subscription?
  payments           Payment[]
  invoices           Invoice[]
  refreshTokens      RefreshToken[]
  dailyUsages        DailyUsage[]
  feedbacks          Feedback[]
  quotaOverride      UserQuotaOverride?
  wallet             Wallet?
  tickets            SupportTicket[]
  limitHitEvents     LimitHitEvent[]
  waitlistEntry      WaitlistEntry?
  issuedDiscountCodes    DiscountCode[]           @relation("IssuedDiscountCodes")
  discountRedemptions    DiscountCodeRedemption[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model Plan {
  id                  String  @id @default(uuid())
  name                String  @unique
  priceMonthly        Int // تومان
  dailyFreeTokens     Int
  monthlyTotalTokens  Int
  allowedModels       Json
  features            Json    @default("{}")
  isActive            Boolean @default(true)
  sortOrder           Int     @default(0)
  isPopular           Boolean @default(false) // نشان «محبوب‌ترین» روی کارت پلن
  featuredModels      Json    @default("[]")  // string[] — زیرمجموعه‌ی ترتیب‌دار allowedModels — مدل‌های ویژه‌ی این پلن (منبع دراپ‌داون چت + چیپ‌های کارت)
  featuredModelsCount Int     @default(5)     // چند مورد از featuredModels روی کارت (قبل از «N مدل دیگر») نشان داده شود
  maxInputTokens        Int     @default(300)
  outputThrottleSteps   Json    @default("[]")
  dailyMessageLimit     Int?
  throttledMessageCount Int?
  throttledInputTokens  Int?
  throttledOutputTokens Int?
  rollingWindowLimit    Int? // سقف پیام در پنجره‌ی لغزان — null = غیرفعال برای این پلن (docs/PRD-global-budget-gateway.md بخش ۸)
  rollingWindowHours    Int  @default(3)

  simpleModel  String? @default("openai/gpt-5-nano") // مدل ثابت برای پیام‌های SIMPLE این پلن — کف‌ترین/دیفالت‌ترین مدل

  // context اختصاصی این پلن — بعد از context عمومی (ChatConfig.globalContextMd) به system prompt چت اصلی اضافه می‌شود
  // (docs/PRD-chat-context-and-summarization.md بخش ۴)
  contextMd String? @db.Text

  // دوره‌ی آزمایشی کاربر تازه (docs/PRD-growth-traction-features.md بخش ۳) — مادامی که
  // User.lifetimeMessageCount از trialMessageThreshold کمتر است، به‌جای محدودیت‌های همیشگی
  // بالا از این مقادیر استفاده می‌شود؛ null = از مقدار همیشگی استفاده کن
  trialMessageThreshold      Int?
  trialDailyMessageLimit     Int?
  trialThrottledMessageCount Int?
  trialRollingWindowLimit    Int?
  trialRollingWindowHours    Int?

  subscriptions Subscription[]
  payments      Payment[]
  routingSteps  PlanRoutingStep[]

  @@map("plans")
}

// استپ‌های مسیریابی مدل بر اساس درصد مصرف بودجه‌ی روزانه — هر پلن چند استپ دارد،
// هر استپ یک استخر مدل ترتیب‌دار (drag&drop در ادمین) برای یک بازه‌ی مصرف مشخص می‌کند
model PlanRoutingStep {
  id           String   @id @default(uuid())
  planId       String
  order        Int                // ترتیب استپ (۱، ۲، ۳، ...)
  thresholdPct Int                // سقف تجمعی درصد مصرف روزانه (مثلاً ۶۰، ۹۰، ۱۰۰)
  models       Json               // string[] ترتیب‌دار — استخر مدل‌های این استپ (زیرمجموعه‌ی allowedModels پلن)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, order])
  @@index([planId])
  @@map("plan_routing_steps")
}

model Subscription {
  id                String             @id @default(uuid())
  userId            String             @unique
  planId            String
  status            SubscriptionStatus @default(ACTIVE)
  periodStart       DateTime
  periodEnd         DateTime
  cancelAtPeriodEnd Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
}

model Conversation {
  id             String    @id @default(uuid())
  userId         String
  title          String?
  model          String
  systemPrompt   String?
  totalTokens    Int       @default(0)
  isArchived     Boolean   @default(false)
  lastMessageAt  DateTime  @default(now())
  createdAt      DateTime  @default(now())
  contextSummary String?
  summarizedAt   DateTime?
  // پیام‌های تا این timestamp قبلاً توی contextSummary خلاصه شده‌اند — برای واکشی فقط
  // پیام‌های «بعد از آخرین خلاصه‌سازی» (docs/PRD-chat-context-and-summarization.md بخش ۳.۱)
  summarizedUntilCreatedAt DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, lastMessageAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  userId         String? // denormalized از conversation.userId — برای groupBy تجمیعی آنالیز مصرف (بخش ۱۷) بدون join
  role           MessageRole
  content        String
  images         Json?
  tokensInput    Int         @default(0)
  tokensOutput   Int         @default(0)
  costToman      Int         @default(0) // هزینه‌ی دقیق همین پیام (تومان)، در لحظه‌ی ایجاد محاسبه‌شده — نه بازمحاسبه‌ی بعدی با نرخ/قیمت فعلی
  costUsdMicros  Int         @default(0)
  costInputUsdMicros  Int    @default(0) // سهم توکن ورودی از costUsdMicros — برای میانگین وزنی قیمت ورودی/خروجی در آنالیز (بدون بازمحاسبه با قیمت فعلی مدل)
  costOutputUsdMicros Int    @default(0)
  model          String?
  topicId        String?
  createdAt      DateTime    @default(now())

  conversation Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedback     MessageFeedback?
  topic        Topic?           @relation(fields: [topicId], references: [id])

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@index([topicId, createdAt])
  @@map("messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Payment {
  id             String          @id @default(uuid())
  userId         String
  planId         String
  amount         Int // تومان — بعد از اعمال تخفیف (اگر کد تخفیف استفاده شده باشد)
  status         PaymentStatus   @default(PENDING)
  provider       PaymentProvider @default(ZARINPAL)
  providerRef    String?         @unique
  refId          String?
  metadata       Json?
  discountCodeId String? // docs/PRD-growth-traction-features.md بخش ۵.۲
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  plan         Plan          @relation(fields: [planId], references: [id])
  discountCode DiscountCode? @relation(fields: [discountCodeId], references: [id])
  invoice      Invoice?
  redemption   DiscountCodeRedemption?

  @@index([userId])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// فقط برای پرداخت‌های COMPLETED صادر می‌شود — رسید داخلی، نه فاکتور رسمی سامانه‌ی مودیان
// (آن بخش موضوع حقوقی/مالیاتی جداست و در این نسخه پیاده‌سازی نشده)
model Invoice {
  id         String   @id @default(uuid())
  number     Int      @unique @default(autoincrement())
  paymentId  String   @unique
  userId     String
  planName   String
  amount     Int // تومان — مبلغ نهایی پرداخت‌شده
  taxAmount  Int      @default(0) // تومان — رزرو برای مالیات بر ارزش افزوده در آینده، فعلاً محاسبه نمی‌شود
  provider   PaymentProvider
  refId      String?
  buyerName  String?
  buyerPhone String
  issuedAt   DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("invoices")
}

enum PaymentProvider {
  ZARINPAL
  VANDAR
  ZIBAL
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model DailyUsage {
  id             String   @id @default(uuid())
  userId         String
  date           DateTime @db.Date
  freeTokensUsed Int      @default(0)
  paidTokensUsed Int      @default(0)
  requestsCount  Int      @default(0)
  costToman      Int      @default(0)
  costUsdMicros  Int      @default(0) // دلار × ۱٬۰۰۰٬۰۰۰ — نگه‌داشتن هزینه‌ی خام دلاری، مستقل از نوسان نرخ ارز

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@map("daily_usage")
}

enum FeedbackCategory {
  FEATURE_REQUEST
  BUG
  UX
  PRICING
  GENERAL
}

model Feedback {
  id        String           @id @default(uuid())
  userId    String?
  category  FeedbackCategory @default(GENERAL)
  content   String
  isChecked Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([isChecked, createdAt])
  @@map("feedbacks")
}

model FeedbackSummary {
  id          String   @id @default(uuid())
  summary     String
  topItems    Json
  totalCount  Int      @default(0)
  checkedUpTo DateTime @default(now())
  createdAt   DateTime @default(now())

  @@map("feedback_summaries")
}

// ─── Quota Overrides ───────────────────────────────────────────────────────────

model UserQuotaOverride {
  id                  String   @id @default(uuid())
  userId              String   @unique
  maxInputTokens      Int?
  outputThrottleSteps Json?
  dailyBudgetToman    Int? // تومان
  note                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_quota_overrides")
}

// ─── Wallet ────────────────────────────────────────────────────────────────────

model Wallet {
  id          String   @id @default(uuid())
  userId      String   @unique
  balanceToman Int     @default(0) // تومان
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String       @id @default(uuid())
  walletId    String
  type        WalletTxType
  amountToman Int // تومان
  description String?
  metadata    Json?
  createdAt   DateTime     @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

enum WalletTxType {
  CREDIT
  DEBIT
}

// ─── Support Tickets ───────────────────────────────────────────────────────────

model SupportTicket {
  id        String         @id @default(uuid())
  userId    String
  subject   String
  body      String
  status    TicketStatus   @default(OPEN)
  priority  TicketPriority @default(NORMAL)
  adminNote String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies TicketReply[]

  @@index([status, createdAt])
  @@map("support_tickets")
}

model TicketReply {
  id        String   @id @default(uuid())
  ticketId  String
  fromAdmin Boolean  @default(false)
  body      String
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_replies")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ModelTier {
  SIMPLE
  MEDIUM
  COMPLEX
}

// چت‌محور (تولید متن) در برابر embedding — docs/PRD-sales-kb-rag-and-plan-context.md.
// جدا نگه‌داشتن این دو نوع در همان جدول AiModel لازم است تا مدل‌های embedding در
// دراپ‌داون‌های چت (پلن‌ها، مسیریاب مدل، کاتالوگ عمومی) سهواً انتخاب‌پذیر نشوند.
enum AiModelType {
  CHAT
  EMBEDDING
}

model AiModel {
  id              String      @id @default(uuid())
  name            String      @unique
  displayName     String
  provider        String
  modelType       AiModelType @default(CHAT)
  inputPricePerM  Float       @default(0)
  outputPricePerM Float       @default(0)
  supportsVision  Boolean     @default(false)
  isActive        Boolean     @default(true)
  sortOrder       Int         @default(0)
  tier            ModelTier   @default(MEDIUM)
  createdAt       DateTime    @default(now())

  // شمارش دقیق توکن — برای مدل‌های OpenAI-family یک tokenizer واقعی داریم؛
  // برای بقیه‌ی پروایدرها (Claude، Grok، ...) که tokenizer آفلاین ندارند،
  // یک نسبت کاراکتر/توکن قابل‌کالیبره در ادمین استفاده می‌شود.
  tokenizerFamily  String @default("approximate") // "o200k_base" | "cl100k_base" | "approximate"
  avgCharsPerToken Float  @default(4) // فقط وقتی tokenizerFamily="approximate" استفاده می‌شود

  @@map("ai_models")
}

// ─── Model Router ──────────────────────────────────────────────────────────────

// تنظیمات سراسری مسیریابی مدل — تک‌رکوردی (singleton، با id ثابت "default")
model ModelRoutingConfig {
  id                  String   @id @default(uuid())
  enabled             Boolean  @default(true)
  simpleKeywords      Json     @default("[]")
  complexKeywords     Json     @default("[]")
  complexLenThreshold Int      @default(600)
  llmFallbackEnabled  Boolean  @default(true)
  llmFallbackModel    String   @default("openai/gpt-4o-mini")
  updatedAt           DateTime @updatedAt

  @@map("model_routing_configs")
}

// لاگ هر تصمیم مسیریابی — برای آنالیتیکس و دیباگ آینده
model ModelRoutingLog {
  id             String    @id @default(uuid())
  userId         String
  conversationId String
  chosenModel    String
  tier           ModelTier
  method         String // 'heuristic' | 'llm' | 'sticky' | 'manual' | 'disabled'
  confidence     Float?
  overrodeManual String? // اگر غیرنال باشد یعنی انتخاب دستی کاربر بی‌صدا override شد
  createdAt      DateTime  @default(now())

  @@index([userId, createdAt])
  @@map("model_routing_logs")
}

// ─── Message Feedback (لایک/دیس‌لایک) ──────────────────────────────────────────

enum FeedbackVote {
  UP
  DOWN
}

model MessageFeedback {
  id        String       @id @default(uuid())
  messageId String       @unique
  userId    String
  vote      FeedbackVote
  comment   String?
  modelUsed String
  isChecked Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([isChecked, createdAt])
  @@index([modelUsed, vote])
  @@map("message_feedbacks")
}

model ModelFeedbackSummary {
  id             String   @id @default(uuid())
  summary        String
  topIssues      Json
  totalProcessed Int      @default(0)
  checkedUpTo    DateTime @default(now())
  createdAt      DateTime @default(now())

  @@map("model_feedback_summaries")
}

model LeadProfile {
  id              String             @id @default(uuid())
  sessionId       String?            @unique
  phone           String?
  name            String?
  age             Int?
  city            String?
  jobTitle        String?
  interests       Json?
  chatHistory     Json?
  recommendedPlan String?
  source          String             @default("pricing_page")
  discountOffered Boolean            @default(false) // docs/PRD-sales-bot-dashboard.md بخش ۸
  followUpStatus  LeadFollowUpStatus @default(NEW)
  guideContentMd  String?            @db.Text // فاز ۲ — صفحه راهنمای AI شخصی‌سازی‌شده
  guideSentAt     DateTime?
  createdAt       DateTime           @default(now())

  @@map("lead_profiles")
}

enum LeadFollowUpStatus {
  NEW
  CONTACTED
  CONVERTED
  DECLINED
}

// ─── Sales Bot (docs/PRD-sales-bot-dashboard.md) ───────────────────────────────

// singleton — دقیقاً یک ردیف، مشابه الگوی ModelRoutingConfig
model SalesBotConfig {
  id                  String   @id @default("singleton")
  contextMd           String   @db.Text
  model               String   @default("openai/gpt-5.4-mini")
  embeddingModel      String   @default("openai/text-embedding-3-small") // docs/PRD-sales-kb-rag-and-plan-context.md
  maxOutputTokens     Int      @default(800) // قبلاً هاردکد 400 در sales.service.ts — حالا از ادمین قابل‌تنظیم
  maxMessages         Int      @default(15)
  discountEnabled     Boolean  @default(true)
  discountMinMessages Int      @default(6)
  discountPromptText  String   @db.Text
  updatedAt           DateTime @updatedAt

  @@map("sales_bot_config")
}

// ─── Chat Config (docs/PRD-chat-context-and-summarization.md) ─────────────────

// singleton — context عمومی + تنظیمات خلاصه‌سازی مبتنی بر توکن برای چت اصلی (دقیقاً الگوی SalesBotConfig)
model ChatConfig {
  id                   String   @id @default("singleton")
  globalContextMd      String   @db.Text @default("")
  summaryTriggerTokens Int      @default(5000) // هر چند توکن از آخرین خلاصه‌سازی، دوباره خلاصه شود
  summaryMaxTokens     Int      @default(200)  // حداکثر طول خروجی خلاصه — کوتاه نگه داشته می‌شود
  updatedAt            DateTime @updatedAt

  @@map("chat_config")
}

// ─── Growth / Traction (docs/PRD-growth-traction-features.md) ─────────────────

// سینگلتون — درصد/مدت تخفیف هر نوع، از پنل ادمین قابل‌تنظیم (بخش ۵.۴)
model GrowthConfig {
  id                        String   @id @default("singleton")
  welcomeDiscountPercent    Int      @default(20)
  welcomeDiscountValidHours Int      @default(72)
  expiryDiscountPercent     Int      @default(15)
  referralDiscountPercent   Int      @default(20)
  referralDiscountValidDays Int      @default(30)
  updatedAt                 DateTime @updatedAt

  @@map("growth_config")
}

// سینگلتون — هدیه‌ی خوش‌آمد (فایل صوتی)؛ audioUrl فقط لینک است، نه آپلود واقعی (بخش ۴.۱)
model OnboardingGift {
  id          String   @id @default("singleton")
  title       String   @default("هدیه ویژه نیوو به کاربران تازه")
  description String   @db.Text @default("")
  audioUrl    String?
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  @@map("onboarding_gift")
}

enum DiscountSource {
  WELCOME_GIFT
  EXPIRY_REMINDER
  REFERRAL
  MANUAL // کد دستی ادمین — کمپین/جشنواره
}

// جدول انعطاف‌پذیر: هم کد شخصی (issuedToUserId ست‌شده) هم کد عمومی/کمپینی (issuedToUserId=null) — بخش ۵.۱
model DiscountCode {
  id              String         @id @default(uuid())
  code            String         @unique
  discountPercent Int
  source          DiscountSource
  issuedToUserId  String?
  maxUses         Int            @default(1)
  usedCount       Int            @default(0)
  expiresAt       DateTime?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())

  issuedToUser User?                    @relation("IssuedDiscountCodes", fields: [issuedToUserId], references: [id], onDelete: Cascade)
  payments     Payment[]
  redemptions  DiscountCodeRedemption[]

  @@index([issuedToUserId])
  @@map("discount_codes")
}

model DiscountCodeRedemption {
  id             String   @id @default(uuid())
  discountCodeId String
  userId         String
  paymentId      String   @unique
  redeemedAt     DateTime @default(now())

  discountCode DiscountCode @relation(fields: [discountCodeId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  payment      Payment      @relation(fields: [paymentId], references: [id])

  @@map("discount_code_redemptions")
}

// رول‌آپ روزانه برای آنالیتیکس اختصاصی ربات فروش — مشابه الگوی DailyUsage
model SalesBotDailyUsage {
  id                     String   @id @default(uuid())
  date                   DateTime @db.Date
  messageCount           Int      @default(0)
  tokensInput            Int      @default(0)
  tokensOutput           Int      @default(0)
  costToman              Int      @default(0)
  costUsdMicros          Int      @default(0)
  sessionsStarted        Int      @default(0)
  discountOffersShown    Int      @default(0)
  phonesCaptured         Int      @default(0)
  // هزینه‌ی embedding — جدا از هزینه‌ی چت بالا (docs/PRD-sales-kb-rag-and-plan-context.md بخش الف.۱۲)
  embeddingCalls         Int      @default(0)
  embeddingTokens        Int      @default(0)
  embeddingCostToman     Int      @default(0)
  embeddingCostUsdMicros Int      @default(0)
  // کلیک روی CTAهای ویجت فروش (هم ردیف پایدار زیر ورودی، هم کارت بزرگ پایان مکالمه)
  ctaFreeStartClicks     Int      @default(0)
  ctaPricingClicks       Int      @default(0)

  @@unique([date])
  @@index([date])
  @@map("sales_bot_daily_usage")
}

// اسنپ‌شات کامل مکالمه‌ی هر سشن ربات فروش — برای دیدن تاریخچه در ادمین و ساخت
// نمونه‌ی جدید پایگاه دانش از یک مکالمه‌ی واقعی. روی هر پیام overwrite می‌شود
// (فرانت هر بار کل تاریخچه را می‌فرستد، پس همیشه آخرین snapshot کامل است).
model SalesChatSession {
  id            String   @id @default(uuid())
  sessionId     String   @unique
  messages      Json // { role: 'user' | 'assistant', content: string }[]
  messageCount  Int      @default(0)
  createdAt     DateTime @default(now())
  lastMessageAt DateTime @default(now())

  @@index([lastMessageAt])
  @@map("sales_chat_sessions")
}

// پایگاه دانش فروش برای بازیابی معنایی (RAG) — docs/PRD-sales-kb-rag-and-plan-context.md بخش الف
enum SalesKbKind {
  EXAMPLE // نمونه‌ی کامل مکالمه (پیام کاربر + پاسخ دستیار)
  OBJECTION // پاسخ به یک اعتراض مشخص
  FAQ // سوال متداول با پاسخ ثابت
  PERSONA_GUIDANCE // راهنمای لحن/تمرکز برای یک پرسونای شغلی
}

model SalesKbEntry {
  id             String      @id @default(uuid())
  kind           SalesKbKind
  label          String // فقط نمایشی در ادمین، مثلاً "اعتراض قیمت — گرونه"
  tags           Json        @default("[]") // string[]
  userMessage    String      @db.Text // نمونه‌ی پیام کاربر — embedding از همین متن ساخته می‌شود
  assistantReply String      @db.Text // پاسخ نمونه — دقیقاً همین شکل به پرامپت اضافه می‌شود
  note           String?     @db.Text // توضیح داخلی برای ادمین — هرگز به مدل فرستاده نمی‌شود
  embedding      Json? // number[] — بردار embedding کش‌شده‌ی userMessage
  embeddingModel String? // شناسه‌ی مدلی که این بردار را ساخته
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([kind])
  @@map("sales_kb_entries")
}

// ─── Usage Analytics ────────────────────────────────────────────────────────────

model Topic {
  id        String    @id @default(uuid())
  name      String    @unique // "برنامه‌نویسی", "ترجمه", "نگارش", "پزشکی", "ریاضی", ...
  keywords  Json // string[] — قابل ویرایش در ادمین
  color     String? // برای نمودار، مثلاً "#4F46E5"
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  messages Message[]

  @@map("topics")
}

// قوانین بخش‌بندی کاربران بر اساس پیام/توکن روزانه — عضویت on-the-fly محاسبه می‌شود
// (docs/PRD-global-budget-gateway.md بخش ۱۷.۶)، این جدول فقط خودِ قانون‌ها را نگه می‌دارد
model UserSegment {
  id                String   @id @default(uuid())
  label             String // "کم‌مصرف", "متوسط", "پرمصرف حرفه‌ای", ...
  minMessagesPerDay Int?
  maxMessagesPerDay Int?
  minTokensPerDay   Int?
  maxTokensPerDay   Int?
  color             String?
  sortOrder         Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("user_segments")
}

model LimitHitEvent {
  id        String        @id @default(uuid())
  userId    String
  type      LimitHitType
  date      DateTime      @db.Date
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([date, type])
  @@index([userId, date])
  @@map("limit_hit_events")
}

enum LimitHitType {
  DAILY_MESSAGE_BLOCKED
  BUDGET_EXCEEDED
  SESSION_LIMIT
  INPUT_TOO_LONG
  ROLLING_WINDOW_BLOCKED
}

// ─── Soft-Launch Waitlist Campaign ──────────────────────────────────────────────
// docs/PRD-global-budget-gateway.md بخش ۱۸

model LaunchCampaign {
  id                        String         @id @default(uuid())
  name                      String
  startAt                   DateTime
  endAt                     DateTime? // null = تا وقتی دستی بسته شود
  capacity                  Int
  grantedCount              Int            @default(0) // افزایش اتمیک — بخش ۱۸.۳
  maxWaitlistSize           Int? // null = بدون سقف — بخش ۱۸.۱۵ («ایمنی هزینه‌ی لیست انتظار»)
  status                    CampaignStatus @default(ACTIVE)

  waitlistMessage           String // پیام انگیزشیِ «پیش‌ثبت‌نام تکمیل شد ...» — همین داخل اپ نمایش داده می‌شود، محدودیت پیامکی ندارد
  waitlistFullMessage       String? // وقتی حتی لیست انتظار هم پر شده — بخش ۱۸.۱۵
  waitlistDailyMessageLimit Int            @default(4)

  displayCounterEnabled     Boolean        @default(true)
  displayInitialPct         Int            @default(20)
  displayFloor              Int            @default(5)
  displayTickSeconds        Int            @default(30)
  displayDecrementMin       Int            @default(1)
  displayDecrementMax       Int            @default(2)

  // پیامک‌ها با الگوی از پیش تأییدشده در پنل کاوه‌نگار ارسال می‌شوند، نه متن آزاد
  // (بخش ۱۸.۷ نسخه‌ی جدید) — دقیقاً همان روشی که برای OTP استفاده می‌شود
  grantedSmsTemplate        String? // نام الگوی کاوه‌نگار برای پیامک «دسترسی باز شد»
  reminderSteps             Json           @default("[]") // [{dayOffset:1, template:"نام الگو در کاوه‌نگار"}, ...]

  createdAt                 DateTime       @default(now())
  createdByAdminId          String?

  waitlistEntries WaitlistEntry[]

  @@index([status])
  @@map("launch_campaigns")
}

enum CampaignStatus {
  ACTIVE
  CLOSED
}

model WaitlistEntry {
  id                   String         @id @default(uuid())
  campaignId           String
  userId               String         @unique
  phone                String
  status               WaitlistStatus @default(WAITING)
  activationToken      String         @unique
  createdAt            DateTime       @default(now())
  grantedAt            DateTime?
  activatedAt          DateTime?
  lastReminderStepSent Int?
  lastReminderSentAt   DateTime?

  campaign LaunchCampaign @relation(fields: [campaignId], references: [id])
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([campaignId, status, createdAt])
  @@map("waitlist_entries")
}

enum WaitlistStatus {
  WAITING
  GRANTED
  ACTIVATED
}

// ─── مقالات (SEO) — docs/PRD-articles-seo-blog.md ──────────────────────────────

model ArticleCategory {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  articles  Article[]

  @@map("article_categories")
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
}

model Article {
  id               String          @id @default(uuid())
  slug             String          @unique
  title            String
  metaDescription  String?         @db.Text
  coverImageUrl    String?
  contentMd        String          @db.Text
  categoryId       String?
  status           ArticleStatus   @default(DRAFT)
  isPinnedInBanner Boolean         @default(false)
  publishedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  category         ArticleCategory? @relation(fields: [categoryId], references: [id])

  @@index([status, publishedAt])
  @@map("articles")
}
