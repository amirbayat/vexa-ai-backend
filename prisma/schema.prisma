  title       String   @default("هدیه ویژه نیوو به کاربران تازه")
  description String   @default("") @db.Text
  audioUrl    String?
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  @@map("onboarding_gift")
}

enum DiscountSource {
  WELCOME_GIFT
  EXPIRY_REMINDER
  REFERRAL
  MANUAL // کد دستی ادمین — کمپین/جشنواره
}

// جدول انعطاف‌پذیر: هم کد شخصی (issuedToUserId ست‌شده) هم کد عمومی/کمپینی (issuedToUserId=null) — بخش ۵.۱
model DiscountCode {
  id              String         @id @default(uuid())
  code            String         @unique
  discountPercent Int
  source          DiscountSource
  issuedToUserId  String?
  maxUses         Int            @default(1)
  usedCount       Int            @default(0)
  expiresAt       DateTime?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())

  issuedToUser User?                    @relation("IssuedDiscountCodes", fields: [issuedToUserId], references: [id], onDelete: Cascade)
  payments     Payment[]
  redemptions  DiscountCodeRedemption[]

  @@index([issuedToUserId])
  @@map("discount_codes")
}

model DiscountCodeRedemption {
  id             String   @id @default(uuid())
  discountCodeId String
  userId         String
  paymentId      String   @unique
  redeemedAt     DateTime @default(now())

  discountCode DiscountCode @relation(fields: [discountCodeId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  payment      Payment      @relation(fields: [paymentId], references: [id])

  @@map("discount_code_redemptions")
}

// رول‌آپ روزانه برای آنالیتیکس اختصاصی ربات فروش — مشابه الگوی DailyUsage
model SalesBotDailyUsage {
  id                     String   @id @default(uuid())
  date                   DateTime @db.Date
  messageCount           Int      @default(0)
  tokensInput            Int      @default(0)
  tokensOutput           Int      @default(0)
  costToman              Int      @default(0)
  costUsdMicros          Int      @default(0)
  sessionsStarted        Int      @default(0)
  discountOffersShown    Int      @default(0)
  phonesCaptured         Int      @default(0)
  // هزینه‌ی embedding — جدا از هزینه‌ی چت بالا (docs/PRD-sales-kb-rag-and-plan-context.md بخش الف.۱۲)
  embeddingCalls         Int      @default(0)
  embeddingTokens        Int      @default(0)
  embeddingCostToman     Int      @default(0)
  embeddingCostUsdMicros Int      @default(0)
  // کلیک روی CTAهای ویجت فروش (هم ردیف پایدار زیر ورودی، هم کارت بزرگ پایان مکالمه)
  ctaFreeStartClicks     Int      @default(0)
  ctaPricingClicks       Int      @default(0)

  @@unique([date])
  @@index([date])
  @@map("sales_bot_daily_usage")
