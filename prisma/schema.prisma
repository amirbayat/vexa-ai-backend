generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String?
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversations  Conversation[]
  messages       Message[]
  subscription   Subscription?
  payments       Payment[]
  refreshTokens  RefreshToken[]
  dailyUsages    DailyUsage[]
  feedbacks      Feedback[]
  quotaOverride  UserQuotaOverride?
  wallet         Wallet?
  tickets        SupportTicket[]
  limitHitEvents LimitHitEvent[]
  waitlistEntry  WaitlistEntry?

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model Plan {
  id                  String  @id @default(uuid())
  name                String  @unique
  priceMonthly        Int
  dailyFreeTokens     Int
  monthlyTotalTokens  Int
  allowedModels       Json
  features            Json    @default("{}")
  isActive            Boolean @default(true)
  sortOrder           Int     @default(0)
  maxInputTokens        Int     @default(300)
  outputThrottleSteps   Json    @default("[]")
  dailyMessageLimit     Int?
  throttledMessageCount Int?
  throttledInputTokens  Int?
  throttledOutputTokens Int?
  rollingWindowLimit    Int? // سقف پیام در پنجره‌ی لغزان — null = غیرفعال برای این پلن (docs/PRD-global-budget-gateway.md بخش ۸)
  rollingWindowHours    Int  @default(3)

  subscriptions Subscription[]
  payments      Payment[]

  @@map("plans")
}

model Subscription {
  id                String             @id @default(uuid())
  userId            String             @unique
  planId            String
  status            SubscriptionStatus @default(ACTIVE)
  periodStart       DateTime
  periodEnd         DateTime
  cancelAtPeriodEnd Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
}

model Conversation {
  id             String    @id @default(uuid())
  userId         String
  title          String?
  model          String
  systemPrompt   String?
  totalTokens    Int       @default(0)
  isArchived     Boolean   @default(false)
  lastMessageAt  DateTime  @default(now())
  createdAt      DateTime  @default(now())
  contextSummary String?
  summarizedAt   DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, lastMessageAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  userId         String? // denormalized از conversation.userId — برای groupBy تجمیعی آنالیز مصرف (بخش ۱۷) بدون join
  role           MessageRole
  content        String
  images         Json?
  tokensInput    Int         @default(0)
  tokensOutput   Int         @default(0)
  costRial       Int         @default(0) // هزینه‌ی دقیق همین پیام، در لحظه‌ی ایجاد محاسبه‌شده — نه بازمحاسبه‌ی بعدی با نرخ/قیمت فعلی
  costUsdMicros  Int         @default(0)
  model          String?
  topicId        String?
  createdAt      DateTime    @default(now())

  conversation Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedback     MessageFeedback?
  topic        Topic?           @relation(fields: [topicId], references: [id])

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@index([topicId, createdAt])
  @@map("messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Payment {
  id          String          @id @default(uuid())
  userId      String
  planId      String
  amount      Int
  status      PaymentStatus   @default(PENDING)
  provider    PaymentProvider @default(ZARINPAL)
  providerRef String?         @unique
  refId       String?
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  ZARINPAL
  VANDAR
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model DailyUsage {
  id             String   @id @default(uuid())
  userId         String
  date           DateTime @db.Date
  freeTokensUsed Int      @default(0)
  paidTokensUsed Int      @default(0)
  requestsCount  Int      @default(0)
  costRial       Int      @default(0)
  costUsdMicros  Int      @default(0) // دلار × ۱٬۰۰۰٬۰۰۰ — نگه‌داشتن هزینه‌ی خام دلاری، مستقل از نوسان نرخ ارز

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@map("daily_usage")
}

enum FeedbackCategory {
  FEATURE_REQUEST
  BUG
  UX
  PRICING
  GENERAL
}

model Feedback {
  id        String           @id @default(uuid())
  userId    String?
  category  FeedbackCategory @default(GENERAL)
  content   String
  isChecked Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([isChecked, createdAt])
  @@map("feedbacks")
}

model FeedbackSummary {
  id          String   @id @default(uuid())
  summary     String
  topItems    Json
  totalCount  Int      @default(0)
  checkedUpTo DateTime @default(now())
  createdAt   DateTime @default(now())

  @@map("feedback_summaries")
}

// ─── Quota Overrides ───────────────────────────────────────────────────────────

model UserQuotaOverride {
  id                  String   @id @default(uuid())
  userId              String   @unique
  maxInputTokens      Int?
  outputThrottleSteps Json?
  dailyBudgetRial     Int?
  note                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_quota_overrides")
}

// ─── Wallet ────────────────────────────────────────────────────────────────────

model Wallet {
  id          String   @id @default(uuid())
  userId      String   @unique
  balanceRial Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String       @id @default(uuid())
  walletId    String
  type        WalletTxType
  amountRial  Int
  description String?
  metadata    Json?
  createdAt   DateTime     @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

enum WalletTxType {
  CREDIT
  DEBIT
}

// ─── Support Tickets ───────────────────────────────────────────────────────────

model SupportTicket {
  id        String         @id @default(uuid())
  userId    String
  subject   String
  body      String
  status    TicketStatus   @default(OPEN)
  priority  TicketPriority @default(NORMAL)
  adminNote String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies TicketReply[]

  @@index([status, createdAt])
  @@map("support_tickets")
}

model TicketReply {
  id        String   @id @default(uuid())
  ticketId  String
  fromAdmin Boolean  @default(false)
  body      String
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_replies")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ModelTier {
  SIMPLE
  MEDIUM
  COMPLEX
}

model AiModel {
  id              String    @id @default(uuid())
  name            String    @unique
  displayName     String
  provider        String
  inputPricePerM  Float     @default(0)
  outputPricePerM Float     @default(0)
  supportsVision  Boolean   @default(false)
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  tier            ModelTier @default(MEDIUM)
  createdAt       DateTime  @default(now())

  // شمارش دقیق توکن — برای مدل‌های OpenAI-family یک tokenizer واقعی داریم؛
  // برای بقیه‌ی پروایدرها (Claude، Grok، ...) که tokenizer آفلاین ندارند،
  // یک نسبت کاراکتر/توکن قابل‌کالیبره در ادمین استفاده می‌شود.
  tokenizerFamily  String @default("approximate") // "o200k_base" | "cl100k_base" | "approximate"
  avgCharsPerToken Float  @default(4) // فقط وقتی tokenizerFamily="approximate" استفاده می‌شود

  @@map("ai_models")
}

// ─── Model Router ──────────────────────────────────────────────────────────────

// تنظیمات سراسری مسیریابی مدل — تک‌رکوردی (singleton، با id ثابت "default")
model ModelRoutingConfig {
  id                  String   @id @default(uuid())
  enabled             Boolean  @default(true)
  simpleKeywords      Json     @default("[]")
  complexKeywords     Json     @default("[]")
  complexLenThreshold Int      @default(600)
  llmFallbackEnabled  Boolean  @default(true)
  llmFallbackModel    String   @default("openai/gpt-4o-mini")
  updatedAt           DateTime @updatedAt

  @@map("model_routing_configs")
}

// لاگ هر تصمیم مسیریابی — برای آنالیتیکس و دیباگ آینده
model ModelRoutingLog {
  id             String    @id @default(uuid())
  userId         String
  conversationId String
  chosenModel    String
  tier           ModelTier
  method         String // 'heuristic' | 'llm' | 'sticky' | 'manual' | 'disabled'
  confidence     Float?
  overrodeManual String? // اگر غیرنال باشد یعنی انتخاب دستی کاربر بی‌صدا override شد
  createdAt      DateTime  @default(now())

  @@index([userId, createdAt])
  @@map("model_routing_logs")
}

// ─── Message Feedback (لایک/دیس‌لایک) ──────────────────────────────────────────

enum FeedbackVote {
  UP
  DOWN
}

model MessageFeedback {
  id        String       @id @default(uuid())
  messageId String       @unique
  userId    String
  vote      FeedbackVote
  comment   String?
  modelUsed String
  isChecked Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([isChecked, createdAt])
  @@index([modelUsed, vote])
  @@map("message_feedbacks")
}

model ModelFeedbackSummary {
  id             String   @id @default(uuid())
  summary        String
  topIssues      Json
  totalProcessed Int      @default(0)
  checkedUpTo    DateTime @default(now())
  createdAt      DateTime @default(now())

  @@map("model_feedback_summaries")
}

model LeadProfile {
  id              String   @id @default(uuid())
  sessionId       String?  @unique
  phone           String?
  name            String?
  age             Int?
  city            String?
  jobTitle        String?
  interests       Json?
  chatHistory     Json?
  recommendedPlan String?
  source          String   @default("pricing_page")
  createdAt       DateTime @default(now())

  @@map("lead_profiles")
}

// ─── Usage Analytics ────────────────────────────────────────────────────────────

model Topic {
  id        String    @id @default(uuid())
  name      String    @unique // "برنامه‌نویسی", "ترجمه", "نگارش", "پزشکی", "ریاضی", ...
  keywords  Json // string[] — قابل ویرایش در ادمین
  color     String? // برای نمودار، مثلاً "#4F46E5"
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  messages Message[]

  @@map("topics")
}

// قوانین بخش‌بندی کاربران بر اساس پیام/توکن روزانه — عضویت on-the-fly محاسبه می‌شود
// (docs/PRD-global-budget-gateway.md بخش ۱۷.۶)، این جدول فقط خودِ قانون‌ها را نگه می‌دارد
model UserSegment {
  id                String   @id @default(uuid())
  label             String // "کم‌مصرف", "متوسط", "پرمصرف حرفه‌ای", ...
  minMessagesPerDay Int?
  maxMessagesPerDay Int?
  minTokensPerDay   Int?
  maxTokensPerDay   Int?
  color             String?
  sortOrder         Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("user_segments")
}

model LimitHitEvent {
  id        String        @id @default(uuid())
  userId    String
  type      LimitHitType
  date      DateTime      @db.Date
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([date, type])
  @@index([userId, date])
  @@map("limit_hit_events")
}

enum LimitHitType {
  DAILY_MESSAGE_BLOCKED
  BUDGET_EXCEEDED
  SESSION_LIMIT
  INPUT_TOO_LONG
  ROLLING_WINDOW_BLOCKED
}

// ─── Soft-Launch Waitlist Campaign ──────────────────────────────────────────────
// docs/PRD-global-budget-gateway.md بخش ۱۸

model LaunchCampaign {
  id                        String         @id @default(uuid())
  name                      String
  startAt                   DateTime
  endAt                     DateTime? // null = تا وقتی دستی بسته شود
  capacity                  Int
  grantedCount              Int            @default(0) // افزایش اتمیک — بخش ۱۸.۳
  maxWaitlistSize           Int? // null = بدون سقف — بخش ۱۸.۱۵ («ایمنی هزینه‌ی لیست انتظار»)
  status                    CampaignStatus @default(ACTIVE)

  waitlistMessage           String // پیام انگیزشیِ «پیش‌ثبت‌نام تکمیل شد ...» — همین داخل اپ نمایش داده می‌شود، محدودیت پیامکی ندارد
  waitlistFullMessage       String? // وقتی حتی لیست انتظار هم پر شده — بخش ۱۸.۱۵
  waitlistDailyMessageLimit Int            @default(4)

  displayCounterEnabled     Boolean        @default(true)
  displayInitialPct         Int            @default(20)
  displayFloor              Int            @default(5)
  displayTickSeconds        Int            @default(30)
  displayDecrementMin       Int            @default(1)
  displayDecrementMax       Int            @default(2)

  // پیامک‌ها با الگوی از پیش تأییدشده در پنل کاوه‌نگار ارسال می‌شوند، نه متن آزاد
  // (بخش ۱۸.۷ نسخه‌ی جدید) — دقیقاً همان روشی که برای OTP استفاده می‌شود
  grantedSmsTemplate        String? // نام الگوی کاوه‌نگار برای پیامک «دسترسی باز شد»
  reminderSteps             Json           @default("[]") // [{dayOffset:1, template:"نام الگو در کاوه‌نگار"}, ...]

  createdAt                 DateTime       @default(now())
  createdByAdminId          String?

  waitlistEntries WaitlistEntry[]

  @@index([status])
  @@map("launch_campaigns")
}

enum CampaignStatus {
  ACTIVE
  CLOSED
}

model WaitlistEntry {
  id                   String         @id @default(uuid())
  campaignId           String
  userId               String         @unique
  phone                String
  status               WaitlistStatus @default(WAITING)
  activationToken      String         @unique
  createdAt            DateTime       @default(now())
  grantedAt            DateTime?
  activatedAt          DateTime?
  lastReminderStepSent Int?
  lastReminderSentAt   DateTime?

  campaign LaunchCampaign @relation(fields: [campaignId], references: [id])
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([campaignId, status, createdAt])
  @@map("waitlist_entries")
}

enum WaitlistStatus {
  WAITING
  GRANTED
  ACTIVATED
}
