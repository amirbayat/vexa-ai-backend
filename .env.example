DATABASE_URL="postgresql://user:pass@localhost:5432/aichat"
# سایز pool اتصال Prisma→Postgres — پیش از مهاجرت به PgBouncer باید زیر max_connections واقعی
# Postgres بماند (پیش‌فرض ۱۰۰، مشترک با migration/psql/مانیتورینگ). بعد از مهاجرت به PgBouncer
# (docs/PERFORMANCE-AND-CONCURRENCY.md بخش ۱۰.۳)، با تعداد replica هماهنگ کنید
DATABASE_POOL_SIZE=20
REDIS_URL="redis://localhost:6379"

JWT_SECRET="change-me-256-bit-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES_IN="30d"

LIARA_AI_BASE_URL="https://your-ai.liara.run/v1"
LIARA_API_KEY="la-xxxxxxxx"

PAYMENT_GATEWAYS="zarinpal"
ZARINPAL_MERCHANT_ID="xxxx-xxxx-xxxx-xxxx"
VANDAR_API_KEY="xxxx-xxxx-xxxx-xxxx"
ZIBAL_MERCHANT_ID="xxxx-xxxx-xxxx-xxxx"

# حالت تست زیبال — true یعنی به‌جای ZIBAL_MERCHANT_ID از merchant تستی «zibal» استفاده می‌شود
ZIBAL_TEST="false"

# لاگین با شماره 09001111111 و کد 123654 بدون ارسال پیامک واقعی
TEST_USER="false"

# محدودیت‌های OTP (به ثانیه) — اختیاری، پیش‌فرض‌ها همین مقادیرند
OTP_TTL_SECONDS=120
OTP_RATE_LIMIT=3
OTP_RATE_WINDOW_SECONDS=600
OTP_ATTEMPT_LIMIT=5
OTP_ATTEMPT_WINDOW_SECONDS=1800

# محدودیت درخواست سراسری کل API (بر اساس userId برای کاربر لاگین‌شده، وگرنه IP) — اختیاری
GLOBAL_RATE_LIMIT=120
GLOBAL_RATE_WINDOW_SECONDS=60

KAVENEGAR_API_KEY="xxxxxxxxxx"
KAVENEGAR_TEMPLATE="loginotp"

# APP_URL = آدرس فرانت (که کاربر توی مرورگر می‌بینه)، API_URL = آدرس خودِ این بک‌اند
# (روی پروداکشن این دو باید دامنه‌ی متفاوت باشند اگر جدا هاست شده‌اند — وگرنه callback درگاه پرداخت کار نمی‌کند)
APP_URL="http://localhost:5173"
API_URL="http://localhost:3001"
PORT=3001

# نمایش/عدم‌نمایش بخش «وضعیت بودجه» و نمودار «مصرف ۳۰ روز اخیر» در پروفایل کاربر — بدون نیاز به rebuild فرانت
SHOW_DAILY_BUDGET="false"
SHOW_MONTHLY_TOKEN_USAGE="false"

# صفحه‌ی ادمین «کدهای OTP فعال» (پشتیبانی/دیباگ) — false یعنی این endpoint هم خاموش می‌شود
OTP_ADMIN_VIEWER_ENABLED="true"

# MinIO — object storage عکس‌های چت (docs/PRD-chat-images.md بخش ۳). روی dev با
# docker-compose خودکار بالا می‌آید (سرویس minio)؛ روی پروداکشن یک اپ جدای Darkube است.
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="chat-images"

# پوش FCM (هم پوش به ادمین admin-notifications، هم پوش به کاربران push-notifications) — اختیاری،
# اگر ست نشود پوش silently غیرفعال می‌ماند (لاگ WARN می‌زند) و بقیه‌ی اپ عادی کار می‌کند.
# مقدار: کل محتوای JSON فایل service account (تک‌خطی) از همان پروژه‌ی Firebase که
# android-app/app/google-services.json از آن گرفته شده — Firebase Console →
# Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
